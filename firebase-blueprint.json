{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and household context.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["parent", "child"] },
        "points": { "type": "number" },
        "householdId": { "type": "string" },
        "targetRewardId": { "type": "string" },
        "email": { "type": "string" },
        "loginCode": { "type": "string" },
        "parentId": { "type": "string" }
      },
      "required": ["displayName", "role", "points", "email"]
    },
    "Household": {
      "title": "Household",
      "description": "A group of users sharing tasks and rewards.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "inviteCode": { "type": "string" },
        "adminId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "inviteCode", "adminId", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A chore or activity that earns points.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "points": { "type": "number" },
        "type": { "type": "string", "enum": ["individual", "first_come"] },
        "distributionType": { "type": "string", "enum": ["first_to_finish", "everyone_must"] },
        "requiresProof": { "type": "boolean" },
        "emoji": { "type": "string" },
        "householdId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "in_progress", "pending", "completed"] },
        "completedBy": { "type": "string" },
        "claimedBy": { "type": "string" },
        "completedByList": { "type": "array", "items": { "type": "string" } },
        "photoURL": { "type": "string" },
        "proofUrl": { "type": "string" },
        "imageUrl": { "type": "string" },
        "icon": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "assignedTo": { "type": "string" }
      },
      "required": ["title", "points", "type", "householdId", "status", "updatedAt"]
    },
    "Reward": {
      "title": "Reward",
      "description": "Something points can be spent on.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "cost": { "type": "number" },
        "householdId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "icon": { "type": "string" },
        "emoji": { "type": "string" },
        "category": { "type": "string" },
        "isSuggestion": { "type": "boolean" },
        "suggestedBy": { "type": "string" },
        "suggestedByPhoto": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "usageType": { "type": "string", "enum": ["once", "always"] },
        "claimed": { "type": "boolean" },
        "claimedBy": { "type": "string" },
        "claimedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "cost", "householdId"]
    },
    "History": {
      "title": "History Entry",
      "description": "Record of points earned or spent.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "householdId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["earn", "spend", "adj"] },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "householdId", "amount", "type", "description", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "App notification for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "householdId": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "householdId", "message", "read", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/households/{householdId}": {
      "schema": "Household",
      "description": "Collection of households."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Collection of chores and tasks."
    },
    "/rewards/{rewardId}": {
      "schema": "Reward",
      "description": "Collection of rewards."
    },
    "/history/{historyId}": {
      "schema": "History",
      "description": "Collection of transactional history."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of user notifications."
    }
  }
}
