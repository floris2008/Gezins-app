rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isMemberOf(householdId) {
      return isSignedIn() && getUserData(request.auth.uid).householdId == householdId;
    }

    function isParent() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'parent';
    }

    function isParentOf(householdId) {
      return isParent() && getUserData(request.auth.uid).householdId == householdId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() <= 100 &&
             data.role in ['parent', 'child'] &&
             data.points is number &&
             data.email == request.auth.token.email;
    }

    function isValidHousehold(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.inviteCode is string && data.inviteCode.size() == 6 &&
             data.adminId == request.auth.uid;
    }

    function isValidTask(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.points is number && data.points >= 0 &&
             data.type in ['individual', 'first_come'] &&
             data.status in ['active', 'pending', 'completed'] &&
             data.householdId is string;
    }

    function isValidReward(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.cost is number && data.cost >= 0 &&
             data.householdId is string;
    }

    function isValidHistory(data) {
      return data.userId is string &&
             data.amount is number &&
             data.type in ['earn', 'spend', 'adj'] &&
             data.timestamp == request.time;
    }

    // --- Rules ---

    // Users
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isMemberOf(existing().householdId));
      allow list: if isSignedIn() && (resource.data.householdId == getUserData(request.auth.uid).householdId);
      
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) && incoming().points == 0;
      
      allow update: if isSignedIn() && (
        // Case 1: Owner updates profile (not points/role/householdId if already set)
        (request.auth.uid == userId && 
         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'householdId']) &&
         (existing().householdId == null || incoming().householdId == existing().householdId)) ||
        
        // Case 2: Parent updates points/role/anything
        (isParentOf(existing().householdId) && 
         isValidUser(incoming()) &&
         incoming().diff(existing()).affectedKeys().hasOnly(['points', 'role', 'displayName', 'photoURL'])) ||

        // Case 3: Child spends points (atomic update logic check would be here, but Firestore rules are limited)
        // Simplified: Parent must handle point distribution usually, but if child buys reward:
        (request.auth.uid == userId && incoming().points < existing().points && 
         incoming().diff(existing()).affectedKeys().hasOnly(['points']))
      );
    }

    // Households
    match /households/{householdId} {
      allow get: if isSignedIn() && (isMemberOf(householdId) || existing().inviteCode != null); // Allow fetching for joining
      allow create: if isSignedIn() && isValidHousehold(incoming());
      allow update: if isSignedIn() && isParentOf(householdId) && incoming().adminId == existing().adminId;
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.householdId);
      allow create: if isSignedIn() && isParentOf(incoming().householdId) && isValidTask(incoming());
      allow update: if isSignedIn() && (
        // Parent updates anything
        (isParentOf(existing().householdId) && isValidTask(incoming())) ||
        // Child completes task
        (isMemberOf(existing().householdId) && 
         existing().status == 'active' && 
         incoming().status == 'pending' &&
         incoming().completedBy == request.auth.uid &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'completedBy', 'photoURL', 'updatedAt']))
      );
      allow delete: if isSignedIn() && isParentOf(existing().householdId);
    }

    // Rewards
    match /rewards/{rewardId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.householdId);
      allow create: if isSignedIn() && isParentOf(incoming().householdId) && isValidReward(incoming());
      allow update: if isSignedIn() && isParentOf(existing().householdId) && isValidReward(incoming());
      allow delete: if isSignedIn() && isParentOf(existing().householdId);
    }

    // History
    match /history/{historyId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.userId == request.auth.uid ? getUserData(request.auth.uid).householdId : resource.data.householdId);
      allow create: if isSignedIn() && (
        (request.auth.uid == incoming().userId || isParentOf(getUserData(incoming().userId).householdId)) &&
        isValidHistory(incoming())
      );
    }

    // Notifications
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isMemberOf(incoming().householdId);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }
  }
}
