rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Get user profile once for role/household checks
    function getProfile(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isParent() {
      return isSignedIn() && getProfile(request.auth.uid).role == 'parent';
    }
    
    function isInHousehold(householdId) {
      return isSignedIn() && getProfile(request.auth.uid).householdId == householdId;
    }

    // 1. Validation Blueprints

    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() <= 100
        && data.role in ['parent', 'child']
        && data.points is number
        && data.email is string && data.email.size() <= 256
        && (!data.keys().hasAny(['householdId']) || data.householdId == null || data.householdId is string)
        && (!data.keys().hasAny(['photoURL']) || data.photoURL == null || data.photoURL is string)
        && (!data.keys().hasAny(['targetRewardId']) || data.targetRewardId == null || data.targetRewardId is string)
        && (!data.keys().hasAny(['loginCode']) || data.loginCode == null || data.loginCode is string)
        && (!data.keys().hasAny(['parentId']) || data.parentId == null || data.parentId is string)
        && (!data.keys().hasAny(['linkedUid']) || data.linkedUid == null || data.linkedUid is string)
        && (!data.keys().hasAny(['id']) || data.id is string)
        && (!data.keys().hasAny(['createdAt']) || data.createdAt is timestamp)
        && (!data.keys().hasAny(['updatedAt']) || data.updatedAt is timestamp);
    }

    function isValidHousehold(data) {
      return data.keys().hasAll(['name', 'inviteCode', 'adminId', 'createdAt'])
        && data.name is string && data.name.size() <= 100
        && data.inviteCode is string && data.inviteCode.size() <= 20
        && (data.adminId == request.auth.uid || isParent())
        && data.createdAt == request.time;
    }

    function isValidTask(data) {
      return data.title is string && data.title.size() <= 200
        && data.points is number && data.points >= 0
        && data.type in ['individual', 'first_come']
        && data.householdId is string
        && data.status in ['active', 'in_progress', 'pending', 'completed']
        && data.updatedAt == request.time;
    }

    function isValidReward(data) {
      return data.keys().hasAll(['title', 'cost', 'householdId'])
        && data.title is string && data.title.size() <= 200
        && data.cost is number && data.cost >= 0
        && data.householdId is string;
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['userId', 'householdId', 'amount', 'type', 'description', 'timestamp'])
        && (data.userId == request.auth.uid || isParent())
        && data.householdId is string
        && data.amount is number
        && data.type in ['earn', 'spend', 'adj']
        && data.description is string && data.description.size() <= 500
        && data.timestamp == request.time;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'householdId', 'message', 'read', 'timestamp'])
        && data.householdId is string
        && data.message is string && data.message.size() <= 500
        && data.read is bool
        && data.timestamp == request.time;
    }

    // 2. Collection Rules

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        resource.data.householdId == getProfile(request.auth.uid).householdId ||
        resource.data.loginCode != null
      );
      allow create: if (isOwner(userId) || isParent()) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isParent()) && (
        // Action: Join/Setup Household (Self)
        (isOwner(userId) && isValidUser(incoming())) ||
        // Action: Admin Parent update Child
        (isParent() && existing().householdId == getProfile(request.auth.uid).householdId && isValidUser(incoming()))
      );
      allow delete: if isParent() && existing().householdId == getProfile(request.auth.uid).householdId;
    }

    match /households/{householdId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidHousehold(incoming());
      allow update: if isSignedIn() && (existing().adminId == request.auth.uid || isParent()) && isValidHousehold(incoming());
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && resource.data.householdId == getProfile(request.auth.uid).householdId;
      allow create: if isParent() && isValidTask(incoming()) && isInHousehold(incoming().householdId);
      allow update: if (isParent() || isInHousehold(existing().householdId)) && (
        // Action: Claim/Complete (Child)
        (incoming().diff(existing()).affectedKeys().hasAny(['status', 'claimedBy', 'completedBy', 'updatedAt', 'proofUrl']) && isValidTask(incoming())) ||
        // Action: Edit (Parent)
        (isParent() && isValidTask(incoming()))
      );
      allow delete: if isParent() && isInHousehold(existing().householdId);
    }

    match /rewards/{rewardId} {
      allow read: if isSignedIn() && resource.data.householdId == getProfile(request.auth.uid).householdId;
      allow create: if (isParent() || isSignedIn()) && isValidReward(incoming()) && isInHousehold(incoming().householdId);
      allow update: if isInHousehold(existing().householdId) && (
        // Action: Claim (Child)
        (incoming().diff(existing()).affectedKeys().hasAny(['claimed', 'claimedBy', 'claimedAt']) && isValidReward(incoming())) ||
        // Action: Edit (Parent)
        (isParent() && isValidReward(incoming()))
      );
      allow delete: if isParent() && isInHousehold(existing().householdId);
    }

    match /history/{historyId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isParent()) && resource.data.householdId == getProfile(request.auth.uid).householdId;
      allow create: if isSignedIn() && isValidHistory(incoming()) && isInHousehold(incoming().householdId);
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && isValidId(incoming().userId) && isInHousehold(incoming().householdId);
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
