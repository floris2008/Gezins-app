rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isMemberOf(householdId) {
      return isSignedIn() && getUserData(request.auth.uid).get('householdId', '') == householdId;
    }

    function isParent() {
      return isSignedIn() && getUserData(request.auth.uid).get('role', '') == 'parent';
    }

    function isParentOf(householdId) {
      return isParent() && getUserData(request.auth.uid).get('householdId', '') == householdId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'role', 'points', 'email']) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.role in ['parent', 'child'] &&
             data.points is number &&
             (data.get('targetRewardId', null) == null || isValidId(data.targetRewardId));
    }

    function isValidHousehold(data) {
      return data.keys().hasAll(['name', 'inviteCode', 'adminId']) &&
             data.name is string && data.name.size() <= 100 &&
             data.inviteCode is string && data.inviteCode.size() == 6 &&
             data.adminId == request.auth.uid;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'points', 'type', 'status', 'householdId']) &&
             data.title is string && data.title.size() <= 200 &&
             data.points is number && data.points >= 0 &&
             data.type in ['individual', 'first_come'] &&
             data.status in ['active', 'in_progress', 'pending', 'completed'] &&
             data.householdId is string &&
             (data.get('distributionType', null) == null || data.distributionType in ['first_to_finish', 'everyone_must']) &&
             (data.get('claimedBy', null) == null || isValidId(data.claimedBy));
    }

    function isValidReward(data) {
      return data.keys().hasAll(['title', 'cost', 'householdId']) &&
             data.title is string && data.title.size() <= 200 &&
             data.cost is number && data.cost >= 0 &&
             data.householdId is string &&
             (data.get('isSuggestion', false) is bool) &&
             (data.get('status', 'approved') in ['pending', 'approved', 'rejected']) &&
             (data.get('usageType', 'always') in ['once', 'always']);
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['userId', 'householdId', 'amount', 'type', 'timestamp']) &&
             data.userId is string &&
             data.householdId is string &&
             data.amount is number &&
             data.type in ['earn', 'spend', 'adj'] &&
             data.timestamp == request.time;
    }

    // --- Rules ---

    // Users
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && (request.auth.uid == userId || (resource.data.get('householdId', null) != null && isMemberOf(resource.data.householdId)));
      allow list: if isSignedIn() && (resource.data.householdId == getUserData(request.auth.uid).householdId);
      
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && 
                       isValidUser(incoming()) && 
                       incoming().email == request.auth.token.email &&
                       incoming().points == 0;
      
      allow update: if isSignedIn() && isValidId(userId) && (
        // Case 1: Owner updates profile
        (request.auth.uid == userId && 
         incoming().email == existing().email &&
         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'householdId', 'targetRewardId', 'updatedAt']) &&
         (existing().get('householdId', null) == null || incoming().householdId == existing().householdId)) ||
        
        // Case 2: Parent updates points/role/anything
        (isParentOf(existing().householdId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['points', 'role', 'displayName', 'photoURL', 'updatedAt']) &&
         (incoming().get('role', 'child') in ['parent', 'child']) &&
         (incoming().get('points', 0) is number)) ||

        // Case 3: Child spends points
        (request.auth.uid == userId && 
         incoming().get('points', existing().points) <= existing().points && 
         incoming().diff(existing()).affectedKeys().hasOnly(['points', 'updatedAt']))
      );
    }

    // Households
    match /households/{householdId} {
      allow get: if isSignedIn() && isValidId(householdId) && (isMemberOf(householdId) || existing().inviteCode != null);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(householdId) && isValidHousehold(incoming());
      allow update: if isSignedIn() && isValidId(householdId) && isParentOf(householdId) && (incoming().get('adminId', existing().adminId) == existing().adminId);
    }

    // Tasks
    match /tasks/{taskId} {
      allow get, list: if isSignedIn() && isMemberOf(resource.data.householdId);
      
      allow create: if isSignedIn() && isValidId(taskId) && isParentOf(incoming().householdId) && isValidTask(incoming());
      allow update: if isSignedIn() && isValidId(taskId) && (
        (isParentOf(existing().householdId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'points', 'type', 'distributionType', 'status', 'completedBy', 'claimedBy', 'proofUrl', 'imageUrl', 'icon', 'updatedAt', 'assignedTo', 'requiresProof', 'emoji']) &&
         (incoming().get('status', 'active') in ['active', 'in_progress', 'pending', 'completed'])) ||
        (isMemberOf(existing().householdId) && (
           // Action: Claim
           (existing().status == 'active' && 
            incoming().status == 'in_progress' &&
            incoming().claimedBy == request.auth.uid &&
            incoming().diff(existing()).affectedKeys().hasOnly(['status', 'claimedBy', 'updatedAt'])) ||
           
           // Action: Unclaim
           (existing().status == 'in_progress' && 
            existing().claimedBy == request.auth.uid &&
            incoming().status == 'active' &&
            incoming().claimedBy == null &&
            incoming().diff(existing()).affectedKeys().hasOnly(['status', 'claimedBy', 'updatedAt'])) ||

           // Action: Complete from active (Individual/First-come)
           (existing().status == 'active' &&
            incoming().status == 'pending' &&
            incoming().completedBy == request.auth.uid &&
            incoming().diff(existing()).affectedKeys().hasOnly(['status', 'completedBy', 'claimedBy', 'proofUrl', 'updatedAt'])) ||

           // Action: Complete from in_progress (Individual/First-come)
           (existing().status == 'in_progress' &&
            existing().claimedBy == request.auth.uid &&
            incoming().status == 'pending' &&
            incoming().completedBy == request.auth.uid &&
            incoming().diff(existing()).affectedKeys().hasOnly(['status', 'completedBy', 'claimedBy', 'proofUrl', 'updatedAt'])) ||
           
           // Action: Everyone must do task completion (add self to list)
           (existing().distributionType == 'everyone_must' &&
            incoming().completedByList.hasAll(existing().get('completedByList', [])) &&
            incoming().completedByList.size() == existing().get('completedByList', []).size() + 1 &&
            incoming().completedByList.hasAll([request.auth.uid]) &&
            incoming().diff(existing()).affectedKeys().hasOnly(['completedByList', 'status', 'claimedBy', 'updatedAt']))
          )
        )
      );
      allow delete: if isSignedIn() && isValidId(taskId) && isParentOf(existing().householdId);
    }

    // Rewards
    match /rewards/{rewardId} {
      allow get, list: if isSignedIn() && isMemberOf(resource.data.householdId);
      
      allow create: if isSignedIn() && isValidId(rewardId) && 
                      isMemberOf(incoming().householdId) && 
                      isValidReward(incoming()) &&
                      (isParentOf(incoming().householdId) || 
                       (incoming().get('isSuggestion', false) == true && incoming().status == 'pending'));
                       
      allow update: if isSignedIn() && isValidId(rewardId) && (
        (isParentOf(existing().householdId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'cost', 'imageUrl', 'icon', 'emoji', 'category', 'isSuggestion', 'suggestedBy', 'suggestedByPhoto', 'status', 'usageType', 'claimed', 'claimedBy', 'claimedAt', 'updatedAt'])) ||
        (isMemberOf(existing().householdId) && (
          // Action: Buy/Claim
          (existing().usageType == 'once' && 
           existing().get('claimed', false) == false &&
           incoming().claimed == true &&
           incoming().claimedBy == request.auth.uid &&
           incoming().diff(existing()).affectedKeys().hasOnly(['claimed', 'claimedBy', 'claimedAt'])) ||
          // Action: Suggestion Edit (if child wants to edit their own pending suggestion - optional but good)
          (existing().isSuggestion == true && 
           existing().suggestedBy == getUserData(request.auth.uid).displayName &&
           incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'emoji', 'category', 'updatedAt']))
        ))
      );
      allow delete: if isSignedIn() && isValidId(rewardId) && (isParentOf(existing().householdId) || (existing().isSuggestion == true && existing().suggestedBy == getUserData(request.auth.uid).displayName));
    }

    // History
    match /history/{historyId} {
      allow get: if isSignedIn() && isValidId(historyId) && isMemberOf(resource.data.householdId);
      allow list: if isSignedIn() && isMemberOf(resource.data.householdId);
      
      allow create: if isSignedIn() && isValidId(historyId) && (
        (request.auth.uid == incoming().userId || isParentOf(getUserData(incoming().userId).householdId)) &&
        isValidHistory(incoming())
      );
    }

    // Notifications
    match /notifications/{notificationId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isMemberOf(resource.data.get('householdId', '')));
      allow create: if isSignedIn() && isValidId(notificationId) && isMemberOf(incoming().householdId);
      allow update: if isSignedIn() && isValidId(notificationId) && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && isValidId(notificationId) && resource.data.userId == request.auth.uid;
    }
  }
}
